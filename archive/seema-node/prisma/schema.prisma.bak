  amount      Decimal  @db.Decimal(15, 2)
  type        String?  @db.VarChar(50)
  matterRef   String?  @map("matter_ref") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([firmId])
