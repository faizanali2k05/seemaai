generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Firm {
  id                      String    @id @default(uuid()) @db.VarChar(36)
  name                    String    @db.VarChar(255)
  sraNumber               String    @unique @map("sra_number") @db.VarChar(20)
  email                   String?   @db.VarChar(255)
  phone                   String?   @db.VarChar(50)
  address                 String?   @db.Text
  postcode                String?   @db.VarChar(10)
  website                 String?   @db.VarChar(255)
  subscriptionTier        String    @default("essentials") @map("subscription_tier") @db.VarChar(20)
  subscriptionPlan        String    @default("free") @map("subscription_plan") @db.VarChar(20)
  subscriptionStatus      String    @default("trial") @map("subscription_status") @db.VarChar(20)
  billingEmail            String?   @map("billing_email") @db.VarChar(255)
  nextBillingDate         String?   @map("next_billing_date") @db.VarChar(30)
  annualCost              Int       @default(0) @map("annual_cost")
  stripeCustomerId        String?   @map("stripe_customer_id") @db.VarChar(100)
  stripeSubscriptionId    String?   @map("stripe_subscription_id") @db.VarChar(100)
  trialEndsAt             DateTime? @map("trial_ends_at")
  practiceAreas           String?   @map("practice_areas") @db.Text
  firmSize                Int       @default(1) @map("firm_size")
  colpName                String?   @map("colp_name") @db.VarChar(255)
  cofaName                String?   @map("cofa_name") @db.VarChar(255)
  mlroName                String?   @map("mlro_name") @db.VarChar(255)
  notificationPreferences String?   @map("notification_preferences") @db.Text
  firmPreferences         String?   @map("firm_preferences") @db.Text
  sraReturnEdits          String?   @map("sra_return_edits") @db.Text
  onboardingStatus        String    @default("pending") @map("onboarding_status") @db.VarChar(20)
  onboardingCompletedAt   DateTime? @map("onboarding_completed_at")
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("firms")
}

model UserAccount {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  firmId              String    @map("firm_id") @db.VarChar(36)
  email               String    @unique @db.VarChar(255)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  role                String    @db.VarChar(50)
  staffId             String?   @map("staff_id") @db.VarChar(36)
  isActive            Boolean   @default(true) @map("is_active")
  lastLogin           DateTime? @map("last_login")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("user_accounts")
}

model UserSession {
  id           String    @id @default(uuid()) @db.VarChar(36)
  userId       String    @map("user_id") @db.VarChar(36)
  firmId       String    @map("firm_id") @db.VarChar(36)
  token        String    @unique @db.VarChar(500)
  refreshToken String?   @unique @map("refresh_token") @db.VarChar(500)
  ipAddress    String?   @map("ip_address") @db.VarChar(50)
  userAgent    String?   @map("user_agent") @db.VarChar(500)
  expiresAt    DateTime  @map("expires_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([firmId])
  @@map("user_sessions")
}

model StaffMember {
  id           String    @id @default(uuid()) @db.VarChar(36)
  firmId       String    @map("firm_id") @db.VarChar(36)
  name         String?   @db.VarChar(255)
  email        String?   @db.VarChar(255)
  role         String?   @db.VarChar(100)
  department   String?   @db.VarChar(100)
  status       String    @default("active") @db.VarChar(20)
  pqe          Int?
  sraId        String?   @map("sra_id") @db.VarChar(50)
  startDate    String?   @map("start_date") @db.VarChar(20)
  lastTraining String?   @map("last_training") @db.VarChar(20)
  phone        String?   @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  externalRef  String?   @map("external_ref") @db.VarChar(100)
  source       String?   @db.VarChar(50)

  @@unique([firmId, externalRef])
  @@index([firmId])
  @@map("staff_members")
}

model StaffTraining {
  id             String   @id @default(uuid()) @db.VarChar(36)
  firmId         String   @map("firm_id") @db.VarChar(36)
  staffId        String?  @map("staff_id") @db.VarChar(36)
  courseName     String?  @map("course_name") @db.VarChar(255)
  provider       String?  @db.VarChar(255)
  status         String   @default("pending") @db.VarChar(20)
  dueDate        String?  @map("due_date") @db.VarChar(20)
  completedDate  String?  @map("completed_date") @db.VarChar(20)
  certificateRef String?  @map("certificate_ref") @db.VarChar(100)
  cpdHours       Int?     @map("cpd_hours")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([firmId])
  @@map("staff_training")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.VarChar(36)
  firmId     String   @map("firm_id") @db.VarChar(36)
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(36)
  userId     String?  @map("user_id") @db.VarChar(36)
  details    String?  @db.Text
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([firmId])
  @@map("audit_logs")
}

model ComplianceAlert {
  id                     String    @id @default(uuid()) @db.VarChar(36)
  firmId                 String    @map("firm_id") @db.VarChar(36)
  alertType              String?   @map("alert_type") @db.VarChar(50)
  severity               String?   @db.VarChar(20)
  title                  String?   @db.VarChar(255)
  description            String?   @db.Text
  caseId                 String?   @map("case_id") @db.VarChar(36)
  clientId               String?   @map("client_id") @db.VarChar(36)
  regulationRef          String?   @map("regulation_ref") @db.VarChar(100)
  actionRequired         String?   @map("action_required") @db.Text
  createdAt              DateTime  @default(now()) @map("created_at")
  acknowledgedAt         DateTime? @map("acknowledged_at")
  resolvedAt             DateTime? @map("resolved_at")
  status                 String    @default("open") @db.VarChar(20)
  overrideSeverity       String?   @map("override_severity") @db.VarChar(20)
  overrideActionRequired String?   @map("override_action_required") @db.Text
  overrideNotes          String?   @map("override_notes") @db.Text
  overriddenBy           String?   @map("overridden_by") @db.VarChar(36)
  overriddenAt           DateTime? @map("overridden_at")

  @@index([firmId])
  @@map("compliance_alerts")
}

model ComplianceCheck {
  id            String    @id @default(uuid()) @db.VarChar(36)
  firmId        String    @map("firm_id") @db.VarChar(36)
  caseId        String?   @map("case_id")
  clientId      String?   @map("client_id")
  checkType     String?   @map("check_type") @db.VarChar(50)
  checkName     String?   @map("check_name") @db.VarChar(255)
  status        String    @default("pending") @db.VarChar(20)
  severity      String?   @db.VarChar(20)
  description   String?   @db.Text
  regulationRef String?   @map("regulation_ref") @db.VarChar(100)
  remediation   String?   @db.Text
  checkedAt     DateTime? @map("checked_at")
  dueDate       String?   @map("due_date") @db.VarChar(20)
  resolvedAt    DateTime? @map("resolved_at")

  @@index([firmId])
  @@map("compliance_checks")
}

model ComplianceTask {
  id                String    @id @default(uuid()) @db.VarChar(36)
  firmId            String    @map("firm_id") @db.VarChar(36)
  taskType          String?   @map("task_type") @db.VarChar(50)
  title             String?   @db.VarChar(255)
  description       String?   @db.Text
  assignedTo        String?   @map("assigned_to") @db.VarChar(36)
  relatedEntityType String?   @map("related_entity_type") @db.VarChar(50)
  relatedEntityId   String?   @map("related_entity_id") @db.VarChar(36)
  priority          String    @default("medium") @db.VarChar(20)
  status            String    @default("pending") @db.VarChar(20)
  dueDate           String?   @map("due_date") @db.VarChar(20)
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([firmId])
  @@map("compliance_tasks")
}

model RiskScore {
  id                   String    @id @default(uuid()) @db.VarChar(36)
  firmId               String    @map("firm_id") @db.VarChar(36)
  entityType           String?   @map("entity_type") @db.VarChar(50)
  entityId             String?   @map("entity_id") @db.VarChar(36)
  overallScore         Int?      @map("overall_score")
  sraScore             Int?      @map("sra_score")
  amlScore             Int?      @map("aml_score")
  cprScore             Int?      @map("cpr_score")
  gdprScore            Int?      @map("gdpr_score")
  limitationScore      Int?      @map("limitation_score")
  calculatedAt         DateTime  @default(now()) @map("calculated_at")
  overrideOverallScore Int?      @map("override_overall_score")
  overrideNotes        String?   @map("override_notes") @db.Text
  overriddenBy         String?   @map("overridden_by") @db.VarChar(36)
  overriddenAt         DateTime? @map("overridden_at")

  @@index([firmId])
  @@map("risk_scores")
}

model SraAuditItem {
  id            String  @id @default(uuid()) @db.VarChar(36)
  firmId        String  @map("firm_id") @db.VarChar(36)
  category      String? @db.VarChar(100)
  itemName      String? @map("item_name") @db.VarChar(255)
  description   String? @db.Text
  status        String  @default("not_reviewed") @db.VarChar(20)
  evidenceRef   String? @map("evidence_ref") @db.VarChar(36)
  lastReviewed  String? @map("last_reviewed") @db.VarChar(30)
  nextReviewDue String? @map("next_review_due") @db.VarChar(20)
  notes         String? @db.Text

  @@index([firmId])
  @@map("sra_audit_items")
}

model SraFeedLog {
  id           String    @id @default(uuid()) @db.VarChar(36)
  feedSource   String?   @map("feed_source") @db.VarChar(100)
  lastChecked  DateTime? @map("last_checked")
  itemsFound   Int       @default(0) @map("items_found")
  newItems     Int       @default(0) @map("new_items")
  status       String?   @db.VarChar(20)
  errorMessage String?   @map("error_message") @db.Text

  @@map("sra_feed_log")
}

model ComplianceScanResult {
  id                      String    @id @default(uuid()) @db.VarChar(36)
  firmId                  String    @map("firm_id") @db.VarChar(36)
  scanDate                DateTime  @default(now()) @map("scan_date")
  category                String?   @db.VarChar(100)
  checkName               String?   @map("check_name") @db.VarChar(255)
  status                  String?   @db.VarChar(20)
  details                 String?   @db.Text
  recommendation          String?   @db.Text
  createdAt               DateTime  @default(now()) @map("created_at")
  overrideStatus          String?   @map("override_status") @db.VarChar(20)
  overrideRecommendation  String?   @map("override_recommendation") @db.Text
  overrideNotes           String?   @map("override_notes") @db.Text
  overriddenBy            String?   @map("overridden_by") @db.VarChar(36)
  overriddenAt            DateTime? @map("overridden_at")

  @@index([firmId])
  @@map("compliance_scan_results")
}

model RegulatoryUpdate {
  id            String   @id @default(uuid()) @db.VarChar(36)
  source        String   @db.VarChar(50)
  sourceUrl     String?  @map("source_url") @db.VarChar(500)
  title         String   @db.VarChar(500)
  summary       String?  @db.Text
  body          String?  @db.Text
  category      String?  @db.VarChar(100)
  publishedDate String?  @map("published_date") @db.VarChar(20)
  effectiveDate String?  @map("effective_date") @db.VarChar(20)
  impactLevel   String   @default("medium") @map("impact_level") @db.VarChar(20)
  tags          String?  @db.Text
  contentHash   String?  @unique @map("content_hash") @db.VarChar(64)
  scrapedAt     DateTime @default(now()) @map("scraped_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("regulatory_updates")
}

model RegulatoryInterpretation {
  id                      String    @id @default(uuid()) @db.VarChar(36)
  firmId                  String    @map("firm_id") @db.VarChar(36)
  updateId                String    @map("update_id") @db.VarChar(36)
  summary                 String    @db.Text
  applicability           String    @db.VarChar(10)
  applicabilityReasoning  String?   @map("applicability_reasoning") @db.Text
  actionItems             String?   @map("action_items") @db.Text
  sourceCitation          String?   @map("source_citation") @db.Text
  confidenceScore         Float?    @map("confidence_score")
  confidenceLabel         String?   @map("confidence_label") @db.VarChar(20)
  modelUsed               String?   @map("model_used") @db.VarChar(50)
  promptTokens            Int?      @map("prompt_tokens")
  completionTokens        Int?      @map("completion_tokens")
  processingTimeMs        Int?      @map("processing_time_ms")
  status                  String    @default("pending") @db.VarChar(20)
  errorMessage            String?   @map("error_message") @db.Text
  overrideApplicability   String?   @map("override_applicability") @db.VarChar(10)
  overrideNotes           String?   @map("override_notes") @db.Text
  overrideActionItems     String?   @map("override_action_items") @db.Text
  overriddenBy            String?   @map("overridden_by") @db.VarChar(36)
  overriddenAt            DateTime? @map("overridden_at")
  deliveredAt             DateTime? @map("delivered_at")
  acknowledgedAt          DateTime? @map("acknowledged_at")
  acknowledgedBy          String?   @map("acknowledged_by") @db.VarChar(36)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("regulatory_interpretations")
}

model CddRecord {
  id                 String    @id @default(uuid()) @db.VarChar(36)
  firmId             String    @map("firm_id") @db.VarChar(36)
  clientName         String    @map("client_name") @db.VarChar(255)
  clientType         String?   @map("client_type") @db.VarChar(100)
  cddLevel           String?   @map("cdd_level") @db.VarChar(50)
  riskLevel          String    @default("medium") @map("risk_level") @db.VarChar(50)
  idVerified         Boolean   @default(false) @map("id_verified")
  addressVerified    Boolean   @default(false) @map("address_verified")
  sofVerified        Boolean   @default(false) @map("sof_verified")
  status             String    @default("pending") @db.VarChar(50)
  nationality        String?   @db.VarChar(100)
  countryOfResidence String?   @map("country_of_residence") @db.VarChar(100)
  companyNumber      String?   @map("company_number") @db.VarChar(50)
  dateOfBirth        DateTime? @map("date_of_birth")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("cdd_records")
}

model SarRecord {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  firmId              String    @map("firm_id") @db.VarChar(36)
  clientName          String    @map("client_name") @db.VarChar(255)
  matterRef           String?   @map("matter_ref") @db.VarChar(100)
  suspicionType       String?   @map("suspicion_type") @db.VarChar(100)
  amount              Decimal?  @db.Decimal(15, 2)
  reportDate          DateTime? @map("report_date")
  mlroDecision        String?   @map("mlro_decision") @db.VarChar(100)
  ncaFiled            Boolean   @default(false) @map("nca_filed")
  status              String    @default("submitted") @db.VarChar(50)
  groundsForSuspicion String?   @map("grounds_for_suspicion") @db.Text
  transactionDetails  String?   @map("transaction_details") @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([firmId])
  @@map("sar_records")
}

model BreachReport {
  id                 String    @id @default(uuid()) @db.VarChar(36)
  firmId             String    @map("firm_id") @db.VarChar(36)
  title              String    @db.VarChar(255)
  description        String?   @db.Text
  breachType         String?   @map("breach_type") @db.VarChar(100)
  severity           String    @default("medium") @db.VarChar(50)
  status             String    @default("open") @db.VarChar(50)
  reportedDate       DateTime? @map("reported_date")
  icoDeadline        DateTime? @map("ico_deadline")
  notificationStatus String    @default("pending") @map("notification_status") @db.VarChar(50)
  affectedRecords    Int       @default(0) @map("affected_records")
  rootCause          String?   @map("root_cause") @db.Text
  resolutionDate     DateTime? @map("resolution_date")
  remediationPlanId  String?   @map("remediation_plan_id") @db.VarChar(36)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("breach_reports")
}

model ClientIntake {
  id                    String    @id @default(uuid()) @db.VarChar(36)
  firmId                String    @map("firm_id") @db.VarChar(36)
  clientName            String?   @map("client_name") @db.VarChar(255)
  clientEmail           String?   @map("client_email") @db.VarChar(255)
  practiceArea          String?   @map("practice_area") @db.VarChar(100)
  status                String    @default("pending") @db.VarChar(20)
  conflictCheckStatus   String?   @map("conflict_check_status") @db.VarChar(20)
  conflictCheckDetails  String?   @map("conflict_check_details") @db.Text
  clientCareLetterSent  Boolean   @default(false) @map("client_care_letter_sent")
  riskLevel             String?   @map("risk_level") @db.VarChar(20)
  riskScore             Int?      @map("risk_score")
  assignedTo            String?   @map("assigned_to") @db.VarChar(36)
  sourceOfFunds         String?   @map("source_of_funds") @db.VarChar(100)
  pepScreening          String?   @map("pep_screening") @db.VarChar(20)
  sanctionsCheck        String?   @map("sanctions_check") @db.VarChar(20)
  cddStatus             String?   @map("cdd_status") @db.VarChar(20)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  externalRef           String?   @map("external_ref") @db.VarChar(100)
  source                String?   @db.VarChar(50)
  clientPhone           String?   @map("client_phone") @db.VarChar(50)
  clientType            String?   @map("client_type") @db.VarChar(50)
  companyName           String?   @map("company_name") @db.VarChar(255)

  @@unique([firmId, externalRef])
  @@index([firmId])
  @@map("client_intakes")
}

model Matter {
  id           String    @id @default(uuid()) @db.VarChar(36)
  firmId       String    @map("firm_id") @db.VarChar(36)
  clientName   String?   @map("client_name") @db.VarChar(255)
  matterType   String?   @map("matter_type") @db.VarChar(100)
  reference    String?   @db.VarChar(100)
  status       String    @default("open") @db.VarChar(20)
  assignedTo   String?   @map("assigned_to") @db.VarChar(36)
  riskLevel    String?   @map("risk_level") @db.VarChar(20)
  feeEstimate  Int?      @map("fee_estimate")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  externalRef  String?   @map("external_ref") @db.VarChar(100)
  source       String?   @db.VarChar(50)
  title        String?   @db.VarChar(255)
  description  String?   @db.Text
  practiceArea String?   @map("practice_area") @db.VarChar(100)
  clientId     String?   @map("client_id") @db.VarChar(36)
  openDate     String?   @map("open_date") @db.VarChar(20)
  closeDate    String?   @map("close_date") @db.VarChar(20)

  @@unique([firmId, externalRef])
  @@index([firmId])
  @@map("matters")
}

model ConflictCheck {
  id           String    @id @default(uuid()) @db.VarChar(36)
  firmId       String    @map("firm_id") @db.VarChar(36)
  clientName   String    @map("client_name") @db.VarChar(255)
  matterType   String?   @map("matter_type") @db.VarChar(100)
  parties      String?   @db.Text
  status       String    @default("pending") @db.VarChar(50)
  conflictType String?   @map("conflict_type") @db.VarChar(100)
  checkedBy    String?   @map("checked_by") @db.VarChar(36)
  resolution   String?   @db.Text
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("conflict_checks")
}

model ConflictParty {
  id        String   @id @default(uuid()) @db.VarChar(36)
  firmId    String   @map("firm_id") @db.VarChar(36)
  partyName String   @map("party_name") @db.VarChar(255)
  partyType String?  @map("party_type") @db.VarChar(50)
  dateAdded DateTime @default(now()) @map("date_added")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([firmId])
  @@map("conflict_parties")
}

model Undertaking {
  id          String    @id @default(uuid()) @db.VarChar(36)
  firmId      String    @map("firm_id") @db.VarChar(36)
  description String    @db.Text
  matterRef   String?   @map("matter_ref") @db.VarChar(100)
  givenTo     String?   @map("given_to") @db.VarChar(255)
  givenBy     String?   @map("given_by") @db.VarChar(255)
  givenDate   DateTime? @map("given_date")
  dueDate     DateTime? @map("due_date")
  status      String    @default("pending") @db.VarChar(50)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("undertakings")
}

model Complaint {
  id              String    @id @default(uuid()) @db.VarChar(36)
  firmId          String    @map("firm_id") @db.VarChar(36)
  complainantName String    @map("complainant_name") @db.VarChar(255)
  complainantType String?   @map("complainant_type") @db.VarChar(100)
  category        String?   @db.VarChar(100)
  description     String?   @db.Text
  priority        String    @default("medium") @db.VarChar(50)
  status          String    @default("open") @db.VarChar(50)
  assignedTo      String?   @map("assigned_to") @db.VarChar(36)
  openedDate      DateTime  @default(now()) @map("opened_date")
  closedDate      DateTime? @map("closed_date")
  resolution      String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("complaints")
}

model EvidenceDocument {
  id          String    @id @default(uuid()) @db.VarChar(36)
  firmId      String    @map("firm_id") @db.VarChar(36)
  title       String    @db.VarChar(255)
  description String?   @db.Text
  category    String?   @db.VarChar(100)
  filePath    String?   @map("file_path") @db.VarChar(500)
  fileSize    Int       @default(0) @map("file_size")
  uploadedBy  String?   @map("uploaded_by") @db.VarChar(36)
  status      String    @default("pending") @db.VarChar(50)
  reviewDate  DateTime? @map("review_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("evidence_documents")
}

model PolicyDocument {
  id           String    @id @default(uuid()) @db.VarChar(36)
  firmId       String    @map("firm_id") @db.VarChar(36)
  title        String    @db.VarChar(255)
  category     String?   @db.VarChar(100)
  status       String    @default("draft") @db.VarChar(50)
  version      String    @default("1.0") @db.VarChar(20)
  content      String?   @db.Text
  lastReviewed DateTime? @map("last_reviewed")
  nextReview   DateTime? @map("next_review")
  owner        String?   @db.VarChar(36)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("policy_documents")
}

model ChaserLog {
  id         String    @id @default(uuid()) @db.VarChar(36)
  firmId     String    @map("firm_id") @db.VarChar(36)
  matterRef  String?   @map("matter_ref") @db.VarChar(100)
  chaserType String?   @map("chaser_type") @db.VarChar(100)
  recipient  String?   @db.VarChar(255)
  subject    String?   @db.VarChar(255)
  status     String    @default("pending") @db.VarChar(50)
  sentAt     DateTime? @map("sent_at")
  responseAt DateTime? @map("response_at")
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([firmId])
  @@map("chaser_logs")
}

model ClientAccount {
  id            String   @id @default(uuid()) @db.VarChar(36)
  firmId        String   @map("firm_id") @db.VarChar(36)
  accountName   String   @map("account_name") @db.VarChar(255)
  accountType   String?  @map("account_type") @db.VarChar(50)
  balance       Decimal  @default(0) @db.Decimal(15, 2)
  status        String   @default("active") @db.VarChar(50)
  bankName      String?  @map("bank_name") @db.VarChar(255)
  accountNumber String?  @map("account_number") @db.VarChar(50)
  sortCode      String?  @map("sort_code") @db.VarChar(10)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([firmId])
  @@map("client_accounts")
}

model Transaction {
  id          String   @id @default(uuid()) @db.VarChar(36)
  firmId      String   @map("firm_id") @db.VarChar(36)
  accountId   String   @map("account_id") @db.VarChar(36)
  date        DateTime
