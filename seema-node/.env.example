DATABASE_URL=postgresql://seema:seema@db:5432/seema
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# FastAPI AI middleware (internal Docker network)
FASTAPI_URL=http://api:8000

# SendGrid
SENDGRID_API_KEY=
EMAIL_FROM=noreply@seemaai.co.uk
EMAIL_FROM_NAME=Seema Compliance

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_ESSENTIALS_MONTHLY=
STRIPE_PRICE_ESSENTIALS_ANNUAL=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=

# Clio Integration
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
CLIO_REDIRECT_URI=https://seemaai.co.uk/api/integrations/clio/callback
CLIO_API_BASE=https://app.clio.com

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated allowed origins. In dev defaults to http://localhost:3000
# In production: CORS_ORIGINS=https://seemaai.co.uk,https://www.seemaai.co.uk
CORS_ORIGINS=http://localhost:3000

# Error aggregation (optional — leave empty to disable Sentry entirely)
SENTRY_DSN=
