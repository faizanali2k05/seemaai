# ============================================================================
# Seema — single environment file for the whole stack.
#
# DO NOT copy this by hand. Run the generator, which creates `.env` with strong
# random secrets already filled in:
#
#     ./scripts/generate-secrets.sh          (Linux / macOS / the VPS)
#     ./scripts/generate-secrets.ps1         (Windows / PowerShell)
#
# After running it, you only need to paste TWO things into `.env`:
#     1. ANTHROPIC_API_KEY      (AI features)
#     2. CLIO_CLIENT_ID / CLIO_CLIENT_SECRET   (Clio PMS sync — optional)
#
# Everything else has a working default or is auto-generated.
# ============================================================================

# ── Domain & general ────────────────────────────────────────────────────────
DOMAIN=app.seemaai.co.uk
ADMIN_EMAIL=admin@seemaai.co.uk
APP_ENV=production

# ── Database (auto-generated — do not edit by hand) ──────────────────────────
POSTGRES_SUPER_USER=seema
POSTGRES_DB=seema
POSTGRES_PASSWORD=__GENERATE__
SEEMA_APP_PASSWORD=__GENERATE__
SEEMA_ADMIN_PASSWORD=__GENERATE__

# ── Auth (auto-generated — do not edit by hand) ──────────────────────────────
JWT_SECRET_KEY=__GENERATE__

# ── AI — REQUIRED ────────────────────────────────────────────────────────────
# Get a key at https://console.anthropic.com. Without it, AI features fall back
# to rule-based behaviour (the app still runs).
ANTHROPIC_API_KEY=

# ── Clio PMS integration — REQUIRED for matter/contact sync ──────────────────
# Create an app at https://app.clio.com/settings/developer_applications.
# Leave blank to run without Clio (integration features stay disabled).
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
CLIO_REDIRECT_URI=https://app.seemaai.co.uk/api/integrations/clio/callback

# ── Email (OPTIONAL — emails are logged to console while blank) ──────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@seemaai.co.uk

# ── Billing (OPTIONAL — billing features disabled while blank) ───────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Error tracking (OPTIONAL) ────────────────────────────────────────────────
SENTRY_DSN=
