# ══════════════════════════════════════════════
# Seema Production Environment Variables
# Copy to .env and fill in real values
# ══════════════════════════════════════════════

# ── Domain ──
DOMAIN=seemaai.co.uk
ADMIN_EMAIL=admin@seemaai.co.uk

# ── Database ──
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── API Workers ──
API_WORKERS=4
CELERY_CONCURRENCY=2

# ── Frontend ──
NEXT_PUBLIC_API_URL=https://seemaai.co.uk/api
