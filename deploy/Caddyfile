# Caddy reverse proxy for the Seema SaaS app.
# - app.seemaai.co.uk is served here (the marketing site at seemaai.co.uk is
#   hosted elsewhere).
# - Caddy automatically obtains + renews a Let's Encrypt certificate for the
#   domain, so there is no certbot/openssl step.
#
# DOMAIN and ADMIN_EMAIL are injected from docker-compose.yml (from .env).

{
	email {$ADMIN_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# API → FastAPI backend (listens on :8000, routes are under /api/*)
	reverse_proxy /api/* api:8000

	# Health probe straight to the API (handy for uptime checks)
	reverse_proxy /health api:8000

	# Everything else → Next.js frontend
	reverse_proxy * web:3000

	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}

	# Access logs go to stdout — view with `docker compose logs -f caddy`.
	log
}

# n8n — preserved from the previous setup so it keeps HTTPS at n8n.seemaai.co.uk.
# n8n runs as a standalone container (not part of this compose project) on the
# host docker bridge, port 5678. We reach it through the host gateway exactly
# like the old nginx did (proxy_pass http://172.17.0.1:5678).
n8n.seemaai.co.uk {
	encode gzip zstd
	reverse_proxy 172.17.0.1:5678
}
