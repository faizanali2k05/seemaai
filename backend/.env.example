# ── Seema API — Environment Variables ──
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# App
APP_ENV=development
DEBUG=false

# Database (Docker Compose default — change for production)
DATABASE_URL=postgresql+asyncpg://seema:seema@db:5432/seema

# Redis (Docker Compose default)
REDIS_URL=redis://redis:6379/0

# Auth — CHANGE THIS! Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-in-production-use-a-64-char-random-string

# CORS — comma-separated origins
CORS_ORIGINS=["http://localhost:3000","https://seemaai.co.uk"]

# AI (optional — leave empty to use rule-based fallbacks)
ANTHROPIC_API_KEY=

# Email (optional — emails are logged to console without this)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@seemaai.co.uk

# Billing (optional — billing features disabled without these)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_ESSENTIALS_MONTHLY=
STRIPE_PRICE_ESSENTIALS_ANNUAL=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=

# Admin DB (BYPASSRLS role — used by webhooks and cross-tenant tasks).
# Alembic also uses this for migrations (DDL needs CREATE on schema public).
ADMIN_DATABASE_URL=postgresql+asyncpg://seema_admin:CHANGE-ME@db:5432/seema

# Migration DB (optional — overrides ADMIN_DATABASE_URL for `alembic upgrade`).
# Only set this if you want migrations to run as a different role than the
# bypass-RLS admin role (rare). env.py falls back to ADMIN_DATABASE_URL,
# then DATABASE_URL, if this is unset.
# MIGRATION_DATABASE_URL=postgresql+asyncpg://seema:seema@db:5432/seema

# Error aggregation (optional — leave empty to disable Sentry entirely)
SENTRY_DSN=
